# Neon DB — get the connection string from https://console.neon.tech
# Use the "Direct connection" string (not the pooled one); the app uses
# Neon's HTTP driver so no connection pool is needed.
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Clerk — fill in from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=

# ElevenLabs
ELEVENLABS_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# ─── Google Vertex AI ─────────────────────────────────────────────────────────
GOOGLE_VERTEX_PROJECT=           # GCP project ID
GOOGLE_VERTEX_LOCATION=global    # "global" required for gemini-3.1-pro/flash preview models
# Optional model overrides (defaults to gemini-3.1-pro-preview / gemini-3.1-flash-lite-preview)
# AI_GENERATION_MODEL=
# AI_EDIT_MODEL=
# Credentials — choose ONE option:
# Option A: service account JSON file path (local dev)
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: individual fields from the service account JSON (deployment)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PRIVATE_KEY_ID=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# ─── Render Worker ────────────────────────────────────────────────────────────
RENDER_WORKER_URL=http://localhost:8787
RENDER_WORKER_SECRET=

# ─── Microsoft Clarity ────────────────────────────────────────────────────────
# Get your project ID from https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── Usage limits (account-level cumulative counts) ───────────────────────────
FREE_TIER_MAX_PROJECTS=5
FREE_TIER_MAX_RENDERS=10
FREE_TIER_MAX_MESSAGES=50
