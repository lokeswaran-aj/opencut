DATABASE_URL=

# Clerk — fill in from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=

# ElevenLabs
ELEVENLABS_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# ─── AI Provider ──────────────────────────────────────────────────────────────
# "anthropic" (default) or "vertex"
AI_PROVIDER=anthropic
# Optional model overrides (sensible defaults are set per provider)
# AI_GENERATION_MODEL=
# AI_EDIT_MODEL=

# ─── Anthropic (AI_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google Vertex AI (AI_PROVIDER=vertex) ───────────────────────────────────
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
# Option A: service account JSON file path (local dev)
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: individual fields from the service account JSON (deployment)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PRIVATE_KEY_ID=

# Cloudflare R2 — fill in after Step 5
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# Render worker base URL — fill in after Step 8
RENDER_WORKER_URL=

# Usage limits
FREE_TIER_MAX_VIDEOS=
